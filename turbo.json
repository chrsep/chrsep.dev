{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "POSTHOG_API_KEY",
        "POSTHOG_HOST",
        "POSTHOG_PROJECT_ID",
        "PUBLIC_POSTHOG_DISABLED",
        "PUBLIC_POSTHOG_ENVIRONMENT",
        "PUBLIC_POSTHOG_HOST",
        "PUBLIC_POSTHOG_KEY",
        "VERCEL_DEPLOYMENT_ID",
        "VERCEL_ENV",
        "VERCEL_GIT_COMMIT_SHA"
      ],
      "outputs": [".svelte-kit/**", ".vercel/**", "dist/**"]
    }
  }
}
