{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "rm -rf ./static/studio && mkdir ./static/studio && cp -R ../studio/dist/* ./static/studio && vite build",
    "export:agent-sessions": "node ./scripts/export-agent-sessions.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --ignore-path .gitignore --write ."
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@posthog/rollup-plugin": "^1.4.7",
    "@poppanator/sveltekit-svg": "^7.0.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "marked": "^17.0.4",
    "mdsvex": "^0.12.7",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "cobe": "^2.0.1",
    "posthog-js": "^1.404.1",
    "studio": "workspace:1.0.0"
  }
}
