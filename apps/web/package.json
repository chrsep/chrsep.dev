{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "rm -rf ./static/studio && mkdir ./static/studio && cp -R ../studio/dist/* ./static/studio && vite build",
    "export:agent-sessions": "node ./scripts/export-agent-sessions.mjs",
    "generate:seo-assets": "node ./scripts/generate-seo-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:seo": "node ./scripts/seo-audit.mjs build",
    "test:seo:live": "node ./scripts/seo-audit.mjs live",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --ignore-path .gitignore --write ."
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@poppanator/sveltekit-svg": "^7.0.0",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "marked": "^18.0.7",
    "mdsvex": "^0.12.8",
    "parse5": "^8.0.1",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-imagetools": "^10.0.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "cobe": "^2.0.1",
    "posthog-js": "^1.407.0",
    "studio": "workspace:1.0.0"
  }
}
