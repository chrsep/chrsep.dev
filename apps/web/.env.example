# Inert defaults for local builds and SEO verification. Override all four only
# in Vercel Production to enable browser analytics without polluting the project.
PUBLIC_POSTHOG_KEY=phc_local_build
PUBLIC_POSTHOG_HOST=https://posthog.invalid
PUBLIC_POSTHOG_ENVIRONMENT=development
PUBLIC_POSTHOG_DISABLED=true

# Build-only source-map upload credentials. Never expose POSTHOG_API_KEY through
# a PUBLIC_ variable. Store real values in Vercel or an ignored .env.local file.
# Leaving either required credential blank keeps source-map generation disabled.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://eu.posthog.com
