# Browser analytics. Set these only for production deployments to keep preview
# traffic out of the production PostHog project.
PUBLIC_POSTHOG_KEY=phc_replace_me
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_POSTHOG_ENVIRONMENT=production
PUBLIC_POSTHOG_DISABLED=false

# Build-only source-map upload credentials. Never expose POSTHOG_API_KEY through
# a PUBLIC_ variable. Store real values in Vercel or an ignored .env.local file.
POSTHOG_API_KEY=phx_replace_me
POSTHOG_PROJECT_ID=replace_me
POSTHOG_HOST=https://eu.posthog.com
